{
  "upstream_url": "https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json",
  "output_file": "model_prices_and_context_window.json",
  "hash_file": "model_prices_and_context_window.sha256",
  "sync_mode": "additive",
  "update_existing": false,
  "prefix_rules": {
    "claude-":  "keep",
    "gpt-":     "keep",
    "gemini-":  "keep",
    "o1-":      "keep",
    "o3-":      "keep",
    "o3":       "keep",
    "o4-":      "keep",
    "deepseek-":"keep",
    "minimax/": "both",
    "zai/":     "strip",
    "moonshot/":"strip"
  },
  "exclude_patterns": [
    "sample_spec"
  ],
  "aliases": {
    "claude-opus-4-6-thinking": {
      "source": "claude-opus-4-6",
      "description": "Thinking variant, same pricing as claude-opus-4-6"
    },
    "gemini-3.1-pro-high": {
      "source": "gemini-3.1-pro-preview",
      "description": "High quality tier, uses preview pricing"
    },
    "gemini-3.1-pro-low": {
      "source": "gemini-3.1-pro-preview",
      "description": "low quality tier, uses preview pricing"
    },
    "gpt-5.3-codex-spark": {
      "source": "gpt-5.3-codex",
      "description": "Spark variant of GPT-5.3 Codex"
    },
    "gemini-3.1-flash-image": {
      "source": "gemini-3.1-flash-image-preview",
      "description": "Alias for gemini-3.1-flash-image-preview"
    },
    "gemini-3-flash": {
      "source": "gemini-3-flash-preview",
      "description": "Alias for gemini-3-flash-preview"
    }
  },
  "cache_1hr_auto_fill": {
    "model_prefix": "claude-",
    "ratio": 1.6
  },
  "custom_models": {}
}
